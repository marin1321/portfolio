---
/**
 * TimelineItem — entry in the vertical experience timeline.
 */

import type { ExperienceEntry } from "@data/experience";
import Localized from "./Localized.astro";
import SkillTag from "./SkillTag.astro";

interface Props {
  entry: ExperienceEntry;
}

const { entry } = Astro.props;
---

<li
  data-reveal
  class="relative pl-8 before:absolute before:left-0 before:top-2 before:h-2.5 before:w-2.5 before:rounded-full before:border-2 before:border-[var(--color-fg)] before:bg-[var(--color-bg)] after:absolute after:left-[5px] after:top-6 after:h-[calc(100%-1rem)] after:w-px after:bg-[var(--color-border)] last:after:hidden"
>
  <div class="flex flex-col gap-3 pb-12">
    <div class="flex flex-wrap items-baseline justify-between gap-2">
      <h3
        class="text-lg font-medium tracking-tight text-[var(--color-fg)]"
      >
        {entry.company}
        <span class="font-normal text-[var(--color-fg-muted)]">
          — <Localized en={entry.content.en.role} es={entry.content.es.role} />
        </span>
      </h3>
      <Localized
        class="text-xs font-medium uppercase tracking-[0.14em] text-[var(--color-fg-muted)]"
        en={entry.content.en.period}
        es={entry.content.es.period}
      />
    </div>

    <Localized
      as="p"
      class="text-[15px] leading-relaxed text-[var(--color-fg-soft)]"
      en={entry.content.en.description}
      es={entry.content.es.description}
    />

    <div class="flex flex-wrap gap-2 pt-1">
      {entry.tags.map((tag) => <SkillTag label={tag} />)}
    </div>
  </div>
</li>
