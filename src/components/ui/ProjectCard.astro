---
/**
 * ProjectCard — project card with bilingual content.
 *
 * Renders both languages (EN/ES) and lets CSS hide the inactive one.
 * Avoids client-side re-renders when toggling the language.
 *
 * Each card mounts its own <ProjectDialog> sibling (RF-10) and exposes
 * a "View details" button that opens it via the native <dialog> API.
 */

import type { Project } from "@data/projects";
import { getStrings } from "@data/i18n";
import Localized from "./Localized.astro";
import SkillTag from "./SkillTag.astro";
import ProjectDialog from "./ProjectDialog.astro";

interface Props {
  project: Project;
}

const { project } = Astro.props;
const en = getStrings("en").work;
const es = getStrings("es").work;

const badgeLabels = {
  production: { en: en.badgeProduction, es: es.badgeProduction },
  client: { en: en.badgeClient, es: es.badgeClient },
};
const highlightLabels = { en: en.highlightLabel, es: es.highlightLabel };
const badge = badgeLabels[project.type];

const dialogId = `project-dialog-${project.id}`;
---

<article
  data-reveal
  data-project-type={project.type}
  data-hidden="false"
  class="group relative flex h-full flex-col gap-5 rounded-[var(--radius-card)] border border-[var(--color-border)] bg-[var(--color-bg)] p-7 shadow-[var(--shadow-card)] transition-[transform,border-color,box-shadow] duration-300 ease-[var(--ease-out-soft)] hover:-translate-y-0.5 hover:border-[var(--color-fg-subtle)] hover:shadow-[var(--shadow-card-hover)]"
>
  <header class="flex flex-wrap items-center gap-3">
    <Localized
      class="inline-flex items-center rounded-full border border-[var(--color-border)] bg-[var(--color-bg-soft)] px-2.5 py-1 text-[11px] font-medium uppercase tracking-[0.14em] text-[var(--color-fg-soft)]"
      en={badge.en}
      es={badge.es}
    />
    <span class="text-xs text-[var(--color-fg-muted)]">{project.company}</span>
  </header>

  <span
    aria-hidden="true"
    class="pointer-events-none absolute right-6 top-6 h-2 w-2 rounded-full bg-[var(--color-fg-subtle)] opacity-0 transition-opacity duration-200 ease-[var(--ease-out-soft)] group-hover:opacity-100"
  ></span>

  <div class="flex flex-1 flex-col gap-4">
    <Localized
      as="h3"
      class="text-xl font-medium leading-snug tracking-tight text-[var(--color-fg)]"
      en={project.content.en.title}
      es={project.content.es.title}
    />

    <Localized
      as="p"
      class="text-[15px] leading-relaxed text-[var(--color-fg-soft)]"
      en={project.content.en.description}
      es={project.content.es.description}
    />

    <div
      class="rounded-lg border-l-2 border-[var(--color-fg)] bg-[var(--color-bg-soft)] py-2 pl-4 pr-3"
    >
      <Localized
        as="p"
        class="text-[11px] font-medium uppercase tracking-[0.14em] text-[var(--color-fg-muted)]"
        en={highlightLabels.en}
        es={highlightLabels.es}
      />
      <Localized
        as="p"
        class="mt-1.5 text-sm leading-relaxed text-[var(--color-fg-soft)]"
        en={project.content.en.highlight}
        es={project.content.es.highlight}
      />
    </div>
  </div>

  <footer class="flex flex-wrap items-center justify-between gap-3 pt-2">
    <div class="flex flex-wrap gap-2">
      {project.tags.map((tag) => <SkillTag label={tag} />)}
    </div>
    <button
      type="button"
      data-project-trigger={dialogId}
      aria-haspopup="dialog"
      aria-controls={dialogId}
      class="inline-flex shrink-0 items-center gap-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-bg)] px-3 py-1.5 text-xs font-medium text-[var(--color-fg-soft)] transition-colors duration-200 ease-[var(--ease-out-soft)] hover:border-[var(--color-fg-subtle)] hover:bg-[var(--color-bg-muted)] hover:text-[var(--color-fg)]"
    >
      <Localized en={en.dialog.open} es={es.dialog.open} />
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="icon-shift h-3.5 w-3.5"
        aria-hidden="true"
        focusable="false"
      >
        <path d="M5 12h14M13 5l7 7-7 7"></path>
      </svg>
    </button>
  </footer>
</article>

<ProjectDialog project={project} />
