---
/**
 * ContactForm — Formspree-backed contact form (RF-11).
 *
 * Endpoint:
 *   Configured at build time via `PUBLIC_FORMSPREE_ENDPOINT`. When
 *   unset, the `<form action>` falls back to a `mailto:` URL so the
 *   section is functional even before Formspree is wired up — useful
 *   for local development and the very first deploy. The submit
 *   handler also flips its strategy: real fetch when an endpoint
 *   exists, native mailto behaviour otherwise.
 *
 * Submission strategy:
 *   - JS path (default): `fetch()` with `Accept: application/json` so
 *     Formspree responds with JSON instead of redirecting. We render
 *     the success / error states inline.
 *   - No-JS path: native form POST. Formspree shows its own
 *     thank-you page; the mailto fallback opens the user's email
 *     client. Either way, the form continues to work without JS.
 *   - Honeypot field (`_gotcha`) sits off-screen with `aria-hidden`
 *     and `tabindex="-1"`; bots fill it eagerly, Formspree drops the
 *     submission.
 *
 * Accessibility:
 *   - Programmatic <label for> on every field, `aria-required`, and
 *     `aria-describedby` pointing at a per-field error slot.
 *   - Errors use `role="alert"` so screen readers announce them when
 *     they appear after submit-time validation.
 *   - Form-level status (success / generic error / offline) goes to
 *     a single polite live region next to the submit button.
 *   - `aria-busy="true"` and `inert` on the form during submission
 *     prevent stray clicks and tell AT the form is unavailable.
 *
 * i18n:
 *   - Static text uses <Localized>, so language switching is a
 *     CSS-only swap (already wired by the global lang toggle).
 *   - Attributes that <Localized> can't reach (placeholders, the
 *     hidden `_subject` value, dynamic error messages) get synced
 *     by the inline script on init and on every `lang:change` event.
 */
import { getStrings, personal } from "@data/i18n";
import { formspreeEndpoint } from "@data/site";
import Localized from "@components/ui/Localized.astro";

const en = getStrings("en").contact.form;
const es = getStrings("es").contact.form;

const fallbackAction = `mailto:${personal.email}`;
const action = formspreeEndpoint ?? fallbackAction;
const isFallback = formspreeEndpoint === null;
/* mailto requires `text/plain` so the form values land in the
   email body; Formspree expects the standard urlencoded payload. */
const enctype = isFallback
  ? "text/plain"
  : "application/x-www-form-urlencoded";
---

<div data-contact-form-root>
  <form
    data-contact-form
    data-fallback={isFallback ? "true" : "false"}
    data-endpoint={formspreeEndpoint ?? ""}
    action={action}
    method="POST"
    enctype={enctype}
    novalidate
    aria-labelledby="contact-form-heading"
    class="rounded-[var(--radius-card)] border border-[var(--color-border)] bg-[var(--color-bg-soft)] p-6 sm:p-8"
  >
    <Localized
      as="h3"
      id="contact-form-heading"
      class="text-lg font-medium text-[var(--color-fg)]"
      en={en.heading}
      es={es.heading}
    />
    <Localized
      as="p"
      class="mt-2 text-sm text-[var(--color-fg-soft)]"
      en={en.intro}
      es={es.intro}
    />

    {/* Honeypot — bots fill anything they can find. Hidden with
        an off-screen position + aria-hidden + tabindex so real
        users (sighted or AT) never reach it. Formspree treats
        `_gotcha` as the canonical honeypot field. */}
    <input
      type="text"
      name="_gotcha"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
      class="contact-honeypot"
    />

    {/* Hidden subject — populated server-side from EN copy and
        re-synced to the active language by the inline script. */}
    <input
      data-subject
      data-subject-en={en.subject}
      data-subject-es={es.subject}
      type="hidden"
      name="_subject"
      value={en.subject}
    />

    <div class="mt-6 grid gap-4 sm:grid-cols-2">
      <div class="flex flex-col gap-1.5">
        <label for="contact-name" class="form-label">
          <Localized en={en.nameLabel} es={es.nameLabel} />
        </label>
        <input
          id="contact-name"
          name="name"
          type="text"
          required
          autocomplete="name"
          aria-required="true"
          aria-describedby="contact-name-error"
          data-placeholder-en={en.namePlaceholder}
          data-placeholder-es={es.namePlaceholder}
          placeholder={en.namePlaceholder}
          class="form-input"
        />
        <p
          id="contact-name-error"
          role="alert"
          class="form-error"
          data-error-required-en={en.errorRequired}
          data-error-required-es={es.errorRequired}
        >
        </p>
      </div>

      <div class="flex flex-col gap-1.5">
        <label for="contact-email" class="form-label">
          <Localized en={en.emailLabel} es={es.emailLabel} />
        </label>
        <input
          id="contact-email"
          name="email"
          type="email"
          required
          autocomplete="email"
          inputmode="email"
          aria-required="true"
          aria-describedby="contact-email-error"
          data-placeholder-en={en.emailPlaceholder}
          data-placeholder-es={es.emailPlaceholder}
          placeholder={en.emailPlaceholder}
          class="form-input"
        />
        <p
          id="contact-email-error"
          role="alert"
          class="form-error"
          data-error-required-en={en.errorRequired}
          data-error-required-es={es.errorRequired}
          data-error-email-en={en.errorEmail}
          data-error-email-es={es.errorEmail}
        >
        </p>
      </div>
    </div>

    <div class="mt-4 flex flex-col gap-1.5">
      <label for="contact-message" class="form-label">
        <Localized en={en.messageLabel} es={es.messageLabel} />
      </label>
      <textarea
        id="contact-message"
        name="message"
        rows="5"
        required
        aria-required="true"
        aria-describedby="contact-message-error"
        data-placeholder-en={en.messagePlaceholder}
        data-placeholder-es={es.messagePlaceholder}
        placeholder={en.messagePlaceholder}
        class="form-input resize-y"></textarea>
      <p
        id="contact-message-error"
        role="alert"
        class="form-error"
        data-error-required-en={en.errorRequired}
        data-error-required-es={es.errorRequired}
      >
      </p>
    </div>

    <div class="mt-6 flex flex-wrap items-center justify-between gap-4">
      <Localized
        as="p"
        class="max-w-sm text-xs text-[var(--color-fg-muted)]"
        en={en.privacy}
        es={es.privacy}
      />
      <button
        type="submit"
        data-submit
        data-label-idle-en={en.submit}
        data-label-idle-es={es.submit}
        data-label-busy-en={en.submitting}
        data-label-busy-es={es.submitting}
        class="btn-primary"
      >
        <span data-submit-label>
          <Localized en={en.submit} es={es.submit} />
        </span>
      </button>
    </div>

    <p
      data-form-status
      role="status"
      aria-live="polite"
      aria-atomic="true"
      class="form-status"
      data-error-generic-en={en.errorGeneric}
      data-error-generic-es={es.errorGeneric}
      data-error-offline-en={en.errorOffline}
      data-error-offline-es={es.errorOffline}
    >
    </p>
  </form>

  {/* Success panel — replaces the form once Formspree accepts a
      submission. Hidden by default; the script reveals it and
      moves focus into it for AT users. */}
  <div
    data-contact-success
    hidden
    tabindex="-1"
    aria-labelledby="contact-success-heading"
    class="rounded-[var(--radius-card)] border border-[var(--color-border)] bg-[var(--color-bg-soft)] p-6 sm:p-8"
  >
    <div class="flex items-start gap-3">
      <span
        aria-hidden="true"
        class="mt-1 inline-flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-[var(--color-fg)] text-[var(--color-bg)]"
      >
        <svg
          viewBox="0 0 24 24"
          width="14"
          height="14"
          fill="none"
          stroke="currentColor"
          stroke-width="2.4"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </span>
      <div>
        <Localized
          as="h3"
          id="contact-success-heading"
          class="text-lg font-medium text-[var(--color-fg)]"
          en={en.successTitle}
          es={es.successTitle}
        />
        <Localized
          as="p"
          class="mt-2 text-sm text-[var(--color-fg-soft)]"
          en={en.successBody}
          es={es.successBody}
        />
      </div>
    </div>
    <button type="button" data-contact-reset class="btn-secondary mt-6">
      <Localized en={en.successReset} es={es.successReset} />
    </button>
  </div>
</div>

<script>
  type Lang = "en" | "es";
  type ErrorType = "required" | "email";

  const root = document.querySelector<HTMLElement>("[data-contact-form-root]");
  const form = root?.querySelector<HTMLFormElement>("[data-contact-form]");
  const success = root?.querySelector<HTMLElement>("[data-contact-success]");
  const status = form?.querySelector<HTMLElement>("[data-form-status]");
  const submitBtn = form?.querySelector<HTMLButtonElement>("[data-submit]");
  const subjectInput = form?.querySelector<HTMLInputElement>("[data-subject]");

  if (!root || !form || !success || !status || !submitBtn || !subjectInput) {
    /* Fail open — without the markup we expect, do nothing and let
       the no-JS form behaviour take over. */
  } else {
    const isFallback = form.dataset.fallback === "true";
    const fields = Array.from(
      form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>(
        "input[name], textarea[name]",
      ),
    ).filter((el) => el.name && !el.name.startsWith("_"));

    const currentLang = (): Lang =>
      document.documentElement.dataset.lang === "es" ? "es" : "en";

    /* ----- language sync (placeholders, subject, button label,
       any active error messages, status message) ---------------- */
    const syncLanguage = () => {
      const lang = currentLang();
      form
        .querySelectorAll<HTMLElement>("[data-placeholder-en]")
        .forEach((el) => {
          const next = el.dataset[
            lang === "es" ? "placeholderEs" : "placeholderEn"
          ];
          if (next) el.setAttribute("placeholder", next);
        });
      subjectInput.value =
        subjectInput.dataset[lang === "es" ? "subjectEs" : "subjectEn"] ?? "";

      const idleLabel =
        submitBtn.dataset[lang === "es" ? "labelIdleEs" : "labelIdleEn"] ?? "";
      const busyLabel =
        submitBtn.dataset[lang === "es" ? "labelBusyEs" : "labelBusyEn"] ?? "";
      submitBtn.setAttribute(
        "aria-label",
        submitBtn.dataset.busy === "true" ? busyLabel : idleLabel,
      );

      /* Re-render any active per-field errors in the new language. */
      fields.forEach((field) => {
        const errType = (field.dataset.errorType as ErrorType | undefined) ??
          undefined;
        if (errType) renderFieldError(field, errType);
      });

      /* Re-render an active form-level status message. */
      const activeStatus = status.dataset.statusKey as
        | "generic"
        | "offline"
        | undefined;
      if (activeStatus) renderStatus(activeStatus);
    };

    /* ----- field error rendering -------------------------------- */
    const errorSlot = (field: HTMLElement) => {
      const id = field.getAttribute("aria-describedby");
      return id ? document.getElementById(id) : null;
    };

    const renderFieldError = (
      field: HTMLInputElement | HTMLTextAreaElement,
      type: ErrorType,
    ) => {
      const slot = errorSlot(field);
      if (!slot) return;
      const lang = currentLang();
      const key =
        type === "email"
          ? lang === "es"
            ? "errorEmailEs"
            : "errorEmailEn"
          : lang === "es"
            ? "errorRequiredEs"
            : "errorRequiredEn";
      const text = slot.dataset[key];
      if (!text) return;
      slot.textContent = text;
      field.setAttribute("aria-invalid", "true");
      field.dataset.errorType = type;
    };

    const clearFieldError = (
      field: HTMLInputElement | HTMLTextAreaElement,
    ) => {
      const slot = errorSlot(field);
      if (slot) slot.textContent = "";
      field.removeAttribute("aria-invalid");
      delete field.dataset.errorType;
    };

    /* ----- form-level status (offline / generic error) ---------- */
    const renderStatus = (key: "generic" | "offline") => {
      const lang = currentLang();
      const dataKey =
        key === "offline"
          ? lang === "es"
            ? "errorOfflineEs"
            : "errorOfflineEn"
          : lang === "es"
            ? "errorGenericEs"
            : "errorGenericEn";
      const text = status.dataset[dataKey];
      if (!text) return;
      status.textContent = text;
      status.dataset.state = "error";
      status.dataset.statusKey = key;
    };

    const clearStatus = () => {
      status.textContent = "";
      delete status.dataset.state;
      delete status.dataset.statusKey;
    };

    /* ----- validation ------------------------------------------- */
    const validate = (): boolean => {
      let firstInvalid: HTMLInputElement | HTMLTextAreaElement | null = null;
      fields.forEach((field) => {
        clearFieldError(field);
        if (field.required && field.value.trim().length === 0) {
          renderFieldError(field, "required");
          if (!firstInvalid) firstInvalid = field;
          return;
        }
        if (
          field instanceof HTMLInputElement &&
          field.type === "email" &&
          !field.checkValidity()
        ) {
          renderFieldError(field, "email");
          if (!firstInvalid) firstInvalid = field;
        }
      });
      if (firstInvalid !== null) {
        (firstInvalid as HTMLElement).focus();
        return false;
      }
      return true;
    };

    fields.forEach((field) => {
      field.addEventListener("input", () => clearFieldError(field));
      field.addEventListener("blur", () => {
        /* Light validation on blur for early feedback, but only
           after a first submit attempt — otherwise we'd nag users
           who haven't tried yet. */
        if (form.dataset.submitted !== "true") return;
        if (field.required && field.value.trim().length === 0) {
          renderFieldError(field, "required");
        } else if (
          field instanceof HTMLInputElement &&
          field.type === "email" &&
          field.value.trim().length > 0 &&
          !field.checkValidity()
        ) {
          renderFieldError(field, "email");
        }
      });
    });

    /* ----- submit handler --------------------------------------- */
    const setBusy = (busy: boolean) => {
      submitBtn.dataset.busy = busy ? "true" : "false";
      submitBtn.disabled = busy;
      form.setAttribute("aria-busy", busy ? "true" : "false");
      const lang = currentLang();
      const labelEl = submitBtn.querySelector<HTMLElement>(
        "[data-submit-label]",
      );
      if (labelEl) {
        const key = busy
          ? lang === "es"
            ? "labelBusyEs"
            : "labelBusyEn"
          : lang === "es"
            ? "labelIdleEs"
            : "labelIdleEn";
        labelEl.textContent = submitBtn.dataset[key] ?? "";
      }
    };

    const showSuccess = () => {
      form.hidden = true;
      success.hidden = false;
      success.focus({ preventScroll: false });
    };

    const resetToForm = () => {
      form.hidden = false;
      success.hidden = true;
      form.reset();
      delete form.dataset.submitted;
      clearStatus();
      fields.forEach(clearFieldError);
      setBusy(false);
      const firstField = fields[0];
      if (firstField) firstField.focus();
    };

    success
      .querySelector<HTMLButtonElement>("[data-contact-reset]")
      ?.addEventListener("click", resetToForm);

    form.addEventListener("submit", async (event) => {
      form.dataset.submitted = "true";
      clearStatus();
      if (!validate()) {
        event.preventDefault();
        return;
      }

      /* Without an endpoint we let the browser handle the mailto:
         action natively — no fetch, no JSON dance. */
      if (isFallback) return;

      event.preventDefault();

      if (typeof navigator !== "undefined" && navigator.onLine === false) {
        renderStatus("offline");
        return;
      }

      setBusy(true);

      try {
        const response = await fetch(form.action, {
          method: "POST",
          headers: { Accept: "application/json" },
          body: new FormData(form),
        });
        if (response.ok) {
          showSuccess();
        } else {
          /* Formspree returns 4xx with a JSON body on validation
             failures; we surface a single localized error line
             rather than rendering their raw response. */
          renderStatus("generic");
        }
      } catch {
        renderStatus("generic");
      } finally {
        setBusy(false);
      }
    });

    syncLanguage();
    document.addEventListener("lang:change", syncLanguage);
  }
</script>
