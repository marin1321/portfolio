---
/**
 * Work — grid of project cards.
 */
import { getStrings } from "@data/i18n";
import { projects } from "@data/projects";
import Localized from "@components/ui/Localized.astro";
import ProjectCard from "@components/ui/ProjectCard.astro";
import ProjectFilter from "@components/ui/ProjectFilter.astro";

const en = getStrings("en").work;
const es = getStrings("es").work;
---

<section id="work" class="section" aria-labelledby="work-heading">
  <div class="container-page">
    <header data-reveal class="max-w-3xl">
      <Localized
        as="p"
        class="section-eyebrow"
        en={en.eyebrow}
        es={es.eyebrow}
      />
      <Localized
        as="h2"
        id="work-heading"
        class="section-heading"
        en={en.heading}
        es={es.heading}
      />
      <Localized
        as="p"
        class="section-description"
        en={en.description}
        es={es.description}
      />
    </header>

    <ProjectFilter />

    <div id="work-grid" class="mt-8 grid gap-6 lg:grid-cols-2">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </div>
</section>
