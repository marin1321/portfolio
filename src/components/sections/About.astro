---
/**
 * About — bio + stack grouped by category + education.
 *
 * The portrait is imported from `src/assets/` (not `public/`) so
 * Astro's `<Image>` can take over: it emits an optimized variant
 * (WebP), inlines the intrinsic `width` / `height` to prevent CLS,
 * lazy-loads it (this section is below the fold), and produces a
 * 1x / 2x srcset for retina sharpness without shipping the full
 * 1024 px source on every viewport.
 */
import { Image } from "astro:assets";
import {
  getStrings,
  stackByCategory,
  stackCategories,
} from "@data/i18n";
import Localized from "@components/ui/Localized.astro";
import SkillTag from "@components/ui/SkillTag.astro";
import portrait from "@/assets/portrait.png";

const en = getStrings("en").about;
const es = getStrings("es").about;
const catEn = stackCategories.en;
const catEs = stackCategories.es;

const categories = (
  Object.keys(stackByCategory) as Array<keyof typeof stackByCategory>
).map((key) => ({
  key,
  en: catEn[key],
  es: catEs[key],
  items: stackByCategory[key],
}));
---

<section
  id="about"
  class="section bg-[var(--color-bg-soft)]"
  aria-labelledby="about-heading"
>
  <div class="container-page grid gap-12 lg:grid-cols-12">
    <header data-reveal class="lg:col-span-4">
      <Localized
        as="p"
        class="section-eyebrow"
        en={en.eyebrow}
        es={es.eyebrow}
      />
      <Localized
        as="h2"
        id="about-heading"
        class="section-heading"
        en={en.heading}
        es={es.heading}
      />

      <figure class="mt-8 w-44 sm:w-56 lg:mt-10 lg:w-full lg:max-w-[18rem]">
        <Image
          src={portrait}
          alt={en.portraitAlt}
          width={320}
          densities={[1, 2]}
          loading="lazy"
          decoding="async"
          data-portrait
          data-alt-en={en.portraitAlt}
          data-alt-es={es.portraitAlt}
          class="block h-auto w-full rounded-[var(--radius-card)] border border-[var(--color-border)] object-cover shadow-[var(--shadow-card)]"
        />
      </figure>
    </header>

    <div class="flex flex-col gap-12 lg:col-span-8">
      <Localized
        as="p"
        data-reveal
        class="max-w-3xl text-base leading-relaxed text-[var(--color-fg-soft)] sm:text-lg"
        en={en.bio}
        es={es.bio}
      />

      <div data-reveal>
        <Localized
          as="h3"
          class="section-eyebrow"
          en={en.stackHeading}
          es={es.stackHeading}
        />
        <dl class="mt-6 grid gap-x-10 gap-y-7 sm:grid-cols-2">
          {
            categories.map((cat) => (
              <div>
                <dt class="mb-3 text-sm font-medium text-[var(--color-fg)]">
                  <Localized en={cat.en} es={cat.es} />
                </dt>
                <dd class="flex flex-wrap gap-2">
                  {cat.items.map((item) => (
                    <SkillTag label={item} />
                  ))}
                </dd>
              </div>
            ))
          }
        </dl>
      </div>

      <div data-reveal>
        <Localized
          as="h3"
          class="section-eyebrow"
          en={en.educationHeading}
          es={es.educationHeading}
        />
        <ul class="mt-5 grid gap-4 sm:grid-cols-2">
          {
            [
              { en: en.educationCurrent, es: es.educationCurrent },
              { en: en.educationPrevious, es: es.educationPrevious },
            ].map((edu) => (
              <li class="rounded-[var(--radius-card)] border border-[var(--color-border)] bg-[var(--color-bg)] p-5">
                <Localized
                  as="p"
                  class="text-sm font-medium text-[var(--color-fg)]"
                  en={edu.en.institution}
                  es={edu.es.institution}
                />
                <Localized
                  as="p"
                  class="mt-1 text-sm text-[var(--color-fg-soft)]"
                  en={edu.en.degree}
                  es={edu.es.degree}
                />
                <Localized
                  as="p"
                  class="mt-2 text-xs text-[var(--color-fg-muted)]"
                  en={edu.en.period}
                  es={edu.es.period}
                />
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>

<script>
  /* Keep the portrait alt text in sync with the active language so
   * screen readers in EN / ES get the right description. Native
   * <img> alt updates aren't always re-announced by ATs, but the
   * accessibility tree is updated correctly for any element queried
   * after the change (e.g. on next focus or when the rotor is
   * reopened on iOS / VoiceOver). */
  const img = document.querySelector<HTMLImageElement>("[data-portrait]");
  if (img) {
    const sync = () => {
      const lang = (document.documentElement.dataset.lang ?? "en") as
        | "en"
        | "es";
      const alt =
        lang === "es"
          ? (img.dataset.altEs ?? img.alt)
          : (img.dataset.altEn ?? img.alt);
      img.alt = alt;
    };
    sync();
    document.addEventListener("lang:change", sync);
  }
</script>
