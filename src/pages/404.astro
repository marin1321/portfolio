---
/**
 * 404 — bilingual not-found page.
 *
 * Astro pre-renders this file to `dist/404.html`. Vercel, Netlify and
 * GitHub Pages all serve it automatically for any unmatched route.
 *
 * Layout mirrors the home page (Navbar + Footer) so visitors keep the
 * full set of nav anchors and the language / theme toggles. Body copy
 * is rendered in both languages via <Localized> and revealed by the
 * existing `html[data-lang]` mechanism — no flash on language switch.
 *
 * <title> and <meta name="description"> can't be swapped client-side
 * with the same data-lang trick, so they're rendered in the SSR
 * default language (English). That's the right call: search engines
 * read the static HTML, and the EN copy is what they should index for
 * an unmatched URL on a primarily EN-facing site.
 */
import BaseLayout from "@layouts/BaseLayout.astro";
import Navbar from "@components/layout/Navbar.astro";
import Footer from "@components/layout/Footer.astro";
import Localized from "@components/ui/Localized.astro";
import { getStrings } from "@data/i18n";

const en = getStrings("en").notFound;
const es = getStrings("es").notFound;
---

<BaseLayout title={en.title} description={en.description}>
  <Navbar />

  <main
    id="main"
    class="container-page flex min-h-[calc(100vh-12rem)] flex-col items-center justify-center gap-6 py-24 text-center sm:py-32"
  >
    <p
      class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-fg-muted)] [animation:var(--animate-fade-in)]"
    >
      <Localized en={en.eyebrow} es={es.eyebrow} />
    </p>

    <Localized
      as="h1"
      class="max-w-2xl text-4xl font-medium tracking-tight text-[var(--color-fg)] sm:text-5xl lg:text-[3.5rem] lg:leading-[1.05] [animation:var(--animate-fade-up)] [animation-delay:80ms]"
      en={en.heading}
      es={es.heading}
    />

    <Localized
      as="p"
      class="max-w-xl text-base leading-relaxed text-[var(--color-fg-soft)] sm:text-lg [animation:var(--animate-fade-up)] [animation-delay:160ms]"
      en={en.subtitle}
      es={es.subtitle}
    />

    <a
      href="/"
      class="btn-primary [animation:var(--animate-fade-up)] [animation-delay:240ms]"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="h-4 w-4"
        aria-hidden="true"
        focusable="false"
      >
        <path d="M19 12H5M12 19l-7-7 7-7"></path>
      </svg>
      <Localized en={en.cta} es={es.cta} />
    </a>
  </main>

  <Footer />
</BaseLayout>
